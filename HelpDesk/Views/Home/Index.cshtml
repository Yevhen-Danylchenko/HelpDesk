@model IEnumerable<HelpDesk.Models.Ticket>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Список заявок</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Нова заявка
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Назва</th>
                        <th>Опис</th>
                        <th>Статус</th>
                        <th>Автор</th>
                        <th>Дата створення</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td>@ticket.Id</td>
                            <td>@ticket.Title</td>
                            <td>@ticket.Description</td>
                            <td>
                                <span class="badge bg-info">@ticket.Status</span>
                            </td>
                            <td>@ticket.AuthorName</td>
                            <td>@ticket.CreatedAt.ToString("g")</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@ticket.Id" class="btn btn-sm btn-warning me-2">
                                    <i class="bi bi-pencil"></i> Редагувати
                                </a>
                                <form asp-action="UpdateStatus" asp-route-id="@ticket.Id" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="Закритий" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-x-circle"></i> Закрити
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


